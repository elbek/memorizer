{
  "name": "quran-memorizer",
  "main": "src/index.ts",
  "compatibility_date": "2024-12-01",
  "rules": [{ "type": "Text", "globs": ["**/*.html"] }],
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "quran-memorizer-db",
      "database_id": "3a465292-b4c5-4f8f-b530-ff5548b8e987"
    }
  ],
  // JWT_SECRET is set via `npx wrangler secret put JWT_SECRET`
  // For local dev, wrangler uses a default. Set in .dev.vars if needed.
  "vars": {}
}
